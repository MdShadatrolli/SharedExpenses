generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
  LEFT
}

enum SplitType {
  EQUAL
  EXACT
  PERCENTAGE
  SHARES
}

enum IssueStatus {
  OPEN
  RESOLVED
  AUTO_FIXED
  REJECTED
}


model User {
  id              String         @id @default(cuid())
  name            String
  email           String         @unique
  passwordHash    String
  role            String         @default("USER")
  memberships     GroupMember[]
  expenses        Expense[]      @relation("ExpenseCreatedBy")
  settlements     Settlement[]   @relation("SettlementCreatedBy")
  auditLogs       AuditLog[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Group {
  id              String         @id @default(cuid())
  name            String
  description     String?
  currencyCode    String
  members         GroupMember[]
  expenses        Expense[]
  settlements     Settlement[]
  importSessions  ImportSession[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model GroupMember {
  id              String             @id @default(cuid())
  groupId         String
  userId          String
  joinedAt        DateTime
  leftAt          DateTime?
  status          MembershipStatus    @default(ACTIVE)
  group           Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenseParts    ExpenseParticipant[]

  @@index([groupId, userId])
  @@index([groupId, status])
}

model Expense {
  id              String               @id @default(cuid())
  groupId         String
  createdById     String
  title           String
  note            String?
  amount          Decimal              @db.Decimal(12, 2)
  currencyCode    String
  expenseDate     DateTime
  splitType       SplitType
  sourceRef       String?
  group           Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy       User                 @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  participants   ExpenseParticipant[]

  @@index([groupId, expenseDate])
  @@unique([groupId, sourceRef])
}

model ExpenseParticipant {
  id              String    @id @default(cuid())
  expenseId       String
  groupMemberId   String
  shareAmount     Decimal?  @db.Decimal(12, 2)
  sharePercent    Decimal?  @db.Decimal(7, 4)
  shareCount      Int?
  expense         Expense   @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  groupMember     GroupMember @relation(fields: [groupMemberId], references: [id], onDelete: Cascade)

  @@index([expenseId])
  @@index([groupMemberId])
}

model Settlement {
  id              String    @id @default(cuid())
  groupId         String
  fromUserId      String
  toUserId        String
  amount          Decimal   @db.Decimal(12, 2)
  currencyCode    String
  settledAt       DateTime
  recordedById    String
  group           Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromUser        User      @relation(fields: [fromUserId], references: [id], onDelete: Restrict)
  toUser          User      @relation(fields: [toUserId], references: [id], onDelete: Restrict)
  recordedBy      User      @relation("SettlementCreatedBy", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([groupId, settledAt])
}

model Currency {
  code            String        @id
  name            String
  symbol          String
  ratesFrom       ExchangeRate[] @relation("BaseCurrency")
  ratesTo         ExchangeRate[] @relation("QuoteCurrency")
}

model ExchangeRate {
  id              String    @id @default(cuid())
  baseCurrencyCode String
  quoteCurrencyCode String
  rate            Decimal   @db.Decimal(18, 8)
  effectiveAt     DateTime
  baseCurrency    Currency  @relation("BaseCurrency", fields: [baseCurrencyCode], references: [code], onDelete: Cascade)
  quoteCurrency   Currency  @relation("QuoteCurrency", fields: [quoteCurrencyCode], references: [code], onDelete: Cascade)

  @@index([baseCurrencyCode, quoteCurrencyCode, effectiveAt])
}

model ImportSession {
  id              String         @id @default(cuid())
  groupId         String
  sourceName      String
  uploadedById    String
  totalRows       Int            @default(0)
  importedRows    Int            @default(0)
  rejectedRows    Int            @default(0)
  autoFixedRows   Int            @default(0)
  manualReviewRows Int           @default(0)
  group           Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  uploadedBy      User           @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  issues          ImportIssue[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model ImportIssue {
  id              String       @id @default(cuid())
  importSessionId String
  rowNumber       Int?
  issueCode       String
  message         String
  status          IssueStatus  @default(OPEN)
  importSession   ImportSession @relation(fields: [importSessionId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())

  @@index([importSessionId, status])
}

model AuditLog {
  id              String    @id @default(cuid())
  actorUserId     String?
  entityType      String
  entityId        String
  action          String
  payload         Json
  createdAt       DateTime  @default(now())
  actor           User?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
}
